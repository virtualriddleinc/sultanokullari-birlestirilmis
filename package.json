{
  "name": "sultan-okullari-birlestirme",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev -p 5001 --webpack",
    "dev:turbo": "cross-env NODE_OPTIONS=--no-deprecation next dev -p 5001",
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "seed:events": "cross-env NODE_OPTIONS=--no-deprecation tsx src/scripts/seed-events.ts",
    "seed:homepage": "cross-env NODE_OPTIONS=--no-deprecation tsx src/scripts/seed-homepage.ts",
    "seed:pages": "cross-env NODE_OPTIONS=--no-deprecation tsx src/scripts/seed-pages.ts",
    "seed:overlay": "cross-env NODE_OPTIONS=--no-deprecation tsx src/scripts/seed-overlay-pages.ts",
    "seed:all": "cross-env NODE_OPTIONS=--no-deprecation tsx src/scripts/seed-all.ts",
    "cms:health": "cross-env NODE_OPTIONS=--no-deprecation tsx src/scripts/cms-health.ts",
    "check:importmap": "tsx src/scripts/check-importmap.ts",
    "import:gorsel": "python3 scripts/import-gorsel-galleries.py",
    "audit:unused-content": "python3 scripts/find-unused-content.py --markdown docs/kullanilmayan-icerik-raporu.md",
    "check:cms-media-paths": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/check-cms-media-paths.ts"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@headlessui/react": "^2.2.10",
    "@hookform/resolvers": "^5.4.0",
    "@payloadcms/db-postgres": "^3.86.0",
    "@payloadcms/email-nodemailer": "^3.86.0",
    "@payloadcms/live-preview-react": "^3.86.0",
    "@payloadcms/next": "^3.86.0",
    "@payloadcms/richtext-lexical": "^3.86.0",
    "@payloadcms/storage-s3": "^3.86.0",
    "@payloadcms/ui": "^3.86.0",
    "@radix-ui/react-accordion": "^1.2.16",
    "@radix-ui/react-tabs": "^1.1.17",
    "@vidstack/react": "^1.15.6",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.42.2",
    "graphql": "^17.0.2",
    "gsap": "^3.15.0",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "next-sitemap": "^4.2.3",
    "payload": "^3.86.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "server-only": "^0.0.1",
    "sharp": "0.34.5",
    "swiper": "^12.2.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.1",
    "typescript": "^5"
  },
  "overrides": {
    "sharp": "0.34.5",
    "drizzle-kit": "0.31.10"
  }
}
