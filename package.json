{
  "name": "sultan-okullari-birlestirme",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev -p 5001 --webpack",
    "dev:turbo": "cross-env NODE_OPTIONS=--no-deprecation next dev -p 5001",
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "seed:events": "cross-env NODE_OPTIONS=--no-deprecation tsx src/scripts/seed-events.ts",
    "seed:homepage": "cross-env NODE_OPTIONS=--no-deprecation tsx src/scripts/seed-homepage.ts",
    "seed:pages": "cross-env NODE_OPTIONS=--no-deprecation tsx src/scripts/seed-pages.ts",
    "seed:overlay": "cross-env NODE_OPTIONS=--no-deprecation tsx src/scripts/seed-overlay-pages.ts",
    "seed:all": "cross-env NODE_OPTIONS=--no-deprecation tsx src/scripts/seed-all.ts",
    "cms:health": "cross-env NODE_OPTIONS=--no-deprecation tsx src/scripts/cms-health.ts",
    "check:importmap": "tsx src/scripts/check-importmap.ts"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@headlessui/react": "^2.2.10",
    "@hookform/resolvers": "^5.2.2",
    "@payloadcms/db-postgres": "^3.85.1",
    "@payloadcms/email-nodemailer": "^3.85.1",
    "@payloadcms/live-preview-react": "^3.85.1",
    "@payloadcms/next": "^3.85.1",
    "@payloadcms/richtext-lexical": "^3.85.1",
    "@payloadcms/storage-s3": "^3.85.1",
    "@payloadcms/ui": "^3.85.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-tabs": "^1.1.13",
    "@vidstack/react": "^1.15.6",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.38.0",
    "graphql": "^17.0.1",
    "gsap": "^3.15.0",
    "lucide-react": "^1.11.0",
    "next": "^16.2.7",
    "next-sitemap": "^4.2.3",
    "payload": "^3.85.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.74.0",
    "server-only": "^0.0.1",
    "sharp": "0.34.5",
    "swiper": "^12.1.3",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.7",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  },
  "overrides": {
    "sharp": "0.34.5"
  }
}
